<div class="stats-table">
    {% for word_list_key, results in search_result_stats.items() %}
        <table class="word-stats">
            <thead>
            <tr>
                <th
                    style="background-color: {{ list_colors[word_list_key] }}"
                    colspan="3"
                >
                    {{ e_search_source_annot_title[word_list_key.name].value }}
                </th>
            </tr>
            </thead>

            {% set words = results['words'] %}
            {% set words_count = results['meta']['words']['total'] %}

            {% if words_count > 0 %}
                <thead>
                <tr class="text-sm">
                    <th>Найденные слова</th>
                    <th>Количество ({{ words_count }})</th>
                    <th>Страницы</th>
                </tr>
                </thead>

                <tbody class="text-sm">
                {% for text_key, stat_form in words.items() %}
                    <tr>
                        <td>
                            {% set show_inagent_link = (word_list_key == search_source_type.INAGENTS) %}
                            {% set data_phrase = text_key %}
                            {% set display_text = stat_form["form"] %}
                            {% include 'components/results/first_cell_inagent.j2' %}
                        </td>
                        <td>{{ stat_form["count"] }}</td>
                        <td>{% if stat_form["pages"] %}стр. {{ stat_form["pages"] | join(", ") }}{% else %}—{% endif %}</td>
                    </tr>
                {% endfor %}
                </tbody>
            {% endif %}

            {% set phrases = results['phrases'] %}
            {% set phrases_count = results['meta']['phrases']['total'] %}

            {% if phrases_count > 0 %}
                <thead>
                {% if words_count > 0 %}
                <tr>
                    <th colspan="3">Совпадение по фразам</th>
                </tr>
                {% endif %}

                <tr class="text-sm">
                    <th>Найденные фразы</th>
                    <th>Количество ({{ phrases_count }})</th>
                    <th>Страницы</th>
                </tr>
                </thead>

                <tbody class="text-sm">
                {% for text_key, stat_form in phrases.items() %}
                    <tr>
                        <td>
                            {% set show_inagent_link = (word_list_key == search_source_type.INAGENTS) %}
                            {% set data_phrase = text_key %}
                            {% set display_text = stat_form["form"] %}
                            {% include 'components/results/first_cell_inagent.j2' %}
                        </td>
                        <td>{{ stat_form["count"] }}</td>
                        <td>{% if stat_form["pages"] %}стр. {{ stat_form["pages"] | join(", ") }}{% else %}—{% endif %}</td>
                    </tr>
                {% endfor %}
                </tbody>
            {% endif %}
        </table>
    {% endfor %}
</div>